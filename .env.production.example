# Production Environment Variables Template
# Copy this to your deployment platform settings (Vercel/Railway/Neon/Upstash)

# --- DATABASE (Neon) ---
DATABASE_URL="postgresql://user:password@hostname/dbname?sslmode=require"

# --- CACHE & QUEUE (Upstash Redis) ---
REDIS_URL="rediss://default:password@hostname:6379"

# --- DISCORD ---
DISCORD_TOKEN="your_bot_token"
DISCORD_CLIENT_ID="1482715896744251494"
DISCORD_PUBLIC_KEY="c6c411f2de7c14d332d80142aeae66ba0dce6a76050dc16fdb728a6b25b7d32c"
DISCORD_GUILD_ID="optional_guild_id"

# --- TWITTER/X API ---
TWITTER_BEARER_TOKEN="your_bearer_token"

# --- AI (OpenAI) ---
OPENAI_API_KEY="your_openai_api_key"

# --- CONFIG ---
NODE_ENV="production"
PORT=3000
